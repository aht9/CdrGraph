<UserControl x:Class="CdrGraph.Desktop.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CdrGraph.Desktop.Views"
             xmlns:viewModels="clr-namespace:CdrGraph.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:ImportViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- این خط مشکل را حل می‌کند: تعریف کانورتر استاندارد WPF -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="Import Excel Data" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#E0E0E0"/>

            <!-- File Selection -->
            <TextBlock Text="Excel File Path:" Foreground="Gray"/>
            <DockPanel Margin="0,5,0,15">
                <Button Content="..." Command="{Binding BrowseCommand}" Width="40" DockPanel.Dock="Right" Margin="5,0,0,0"/>
                <TextBox Text="{Binding FilePath}" IsReadOnly="True" Padding="5"/>
            </DockPanel>

            <!-- Column Mapping -->
            <GroupBox Header="Map Columns" Foreground="White" BorderBrush="#444" Padding="10">
                <StackPanel>
                    <TextBlock Text="Source Number:" Margin="0,5" Foreground="#CCC"/>
                    <ComboBox ItemsSource="{Binding DetectedHeaders}" SelectedItem="{Binding SelectedSource}"/>

                    <TextBlock Text="Target Number:" Margin="0,10,0,5" Foreground="#CCC"/>
                    <ComboBox ItemsSource="{Binding DetectedHeaders}" SelectedItem="{Binding SelectedTarget}"/>

                    <TextBlock Text="Duration / Weight:" Margin="0,10,0,5" Foreground="#CCC"/>
                    <ComboBox ItemsSource="{Binding DetectedHeaders}" SelectedItem="{Binding SelectedDuration}"/>
                </StackPanel>
            </GroupBox>

            <!-- Action Button -->
            <Button Content="Generate Graph" 
                    Command="{Binding AnalyzeCommand}" 
                    Height="40" Margin="0,20,0,0"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"/>

            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0" 
                         Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
