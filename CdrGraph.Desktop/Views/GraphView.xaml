<UserControl x:Class="CdrGraph.Desktop.Views.GraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CdrGraph.Desktop.Views"
             xmlns:viewModels="clr-namespace:CdrGraph.Desktop.ViewModels"
             xmlns:wpf="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             d:DataContext="{d:DesignInstance Type=viewModels:GraphViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <!-- بوم نقاشی SkiaSharp -->
        <!-- PaintSurface رویدادی است که در آن رسم انجام می‌شود -->
        <wpf:SKElement Name="GraphCanvas" 
                        PaintSurface="OnPaintSurface"
                        MouseDown="OnMouseDown"
                        MouseMove="OnMouseMove"
                        MouseUp="OnMouseUp"
                        MouseWheel="OnMouseWheel"/>

        <!-- پنل اطلاعات (Overlay) -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Background="#AA000000" CornerRadius="5" Margin="10" Padding="10">
            <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold"/>
        </Border>
        
        <TextBlock Text="Left Drag: Pan | Wheel: Zoom" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                   Foreground="Gray" Margin="10" Opacity="0.5"/>
    </Grid>
</UserControl>
